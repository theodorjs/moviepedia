# Copy this file to ".env" and fill in your own keys.

# TMDb — create a key at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key
VITE_TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token

# OMDb — free key for IMDb / Rotten Tomatoes / Metacritic ratings
# https://www.omdbapi.com/apikey.aspx  (optional; ratings are hidden without it)
VITE_OMDB_API_KEY=your_omdb_api_key
